# ─────────────────────────────────────────────────────────────
#  .env.example  –  Copy this to .env and fill in your values
#                   Never commit .env to git!
# ─────────────────────────────────────────────────────────────

# Website credentials
SITE_LOGIN_URL=https://example.com/login
SITE_ORDERS_URL=https://example.com/orders
SITE_USERNAME=your@email.com
SITE_PASSWORD=yourpassword

# Google Sheets
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEET_NAME=Orders
GOOGLE_KEY_FILE=./service-account-key.json

# Optional tweaks
HEADLESS=true        # set to false to watch the browser
DELAY_MS=800         # ms to wait between order detail pages
